# Copy to .env and fill in. Never commit .env.

# --- LLM (OpenRouter) ---
# Real LLM. Get a key at https://openrouter.ai/keys
# Costs ~$0.0001 per sample doc with gpt-4o-mini.
# Leave blank or set LLM_PROVIDER=mock to skip the API call entirely.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- LLM provider toggle ---
# "openrouter" → call OpenRouter (requires OPENROUTER_API_KEY)
# "mock"       → deterministic regex parser, no API calls, runs in CI
LLM_PROVIDER=mock

# --- Mock CRM ---
CRM_BASE_URL=http://127.0.0.1:8765
# Server-side fault injection (mock CRM only)
CRM_FAULT_RATE_429=0.10
CRM_FAULT_RATE_503=0.05
CRM_LATENCY_MS_MIN=20
CRM_LATENCY_MS_MAX=120

# --- Resilience knobs (client) ---
RETRY_MAX_ATTEMPTS=5
RETRY_INITIAL_BACKOFF_S=0.5
RETRY_MAX_BACKOFF_S=8.0
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_S=15.0

# --- Storage ---
DATABASE_URL=sqlite:///data/onboard.db

# --- Logging ---
LOG_LEVEL=INFO
